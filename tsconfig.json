{
  "compilerOptions": {
    "target": "es2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ESNext",
      "DOM",
      "webworker"
    ],
    "rewriteRelativeImportExtensions": true,
    "allowUmdGlobalAccess": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "cypress",
    "dist"
  ]
}